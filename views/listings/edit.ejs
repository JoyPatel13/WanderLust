<% layout('layouts/boilerplate')%>
    
    <br>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h3>Edit Your Listing</h3>
    <form method="post" action="/listings/<%=listing._id%>?_method=PUT">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input class="form-control" name="listing[title]" value="<%=listing.title%>" type="text">
            
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">description</label>
            <br><br>
            <textarea class="form-control" name="listing[description]"  type="text"><%= listing.description %></textarea>
            <br>
            
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Image URL/Link</label>
            <input class="form-control" name="listing[image][url]"   value="<%= listing.image?.url %>" type="text" >
            <br>
            
        </div>
        <div class="row ">

            <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price</label>
                <input class="form-control" name="listing[price]" value="<%=listing.price%>" type="number">
                <br>
                
            </div>
            <div class="mb-3 col-md-4">
                <label for="country" class="form-label">Country</label>
                <input class="form-control"  name="listing[country]" value="<%=listing.country%>" type="text" >
                <br>
                
            </div>
        </div>
        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input class="form-control" name="listing[location]" value= "<%=listing.location%>" type="text" >
            <br>
        </div>
        <button class="btn btn-dark add-btn mt-3">Edit</button>

    </form>

        </div>
    </div>
    